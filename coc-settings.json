{
  "languageserver": {
    "golang": {
      "command": "gopls",
      "rootPatterns": ["go.mod", ".vim/", ".git/", ".hg/"],
      "filetypes": ["go"]
    }
  },
  "go.goplsOptions": {
    "completeUnimported": true
  },
  "dart.lineLength": 100,
  "flutter.lsp.debug": true,
  "flutter.sdk.path": "C:/flutter",
  "coc.preferences.formatOnSaveFiletypes": [
    "dart",
    "json",
    "go",
    "typescript",
    "javascript",
    "proto"
  ],
  "explorer.icon.enableNerdfont": true,
  "explorer.width": 60
}
